{
  "compilerOptions": {
    "strict": true,
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "noUncheckedIndexedAccess": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "exactOptionalPropertyTypes": false,
    "sourceMap": true,
    "outDir": "static/dist",
    "rootDir": "static/ts",
    "types": ["bun-types"]
  },
  "include": ["static/ts/**/*.ts"]
}
