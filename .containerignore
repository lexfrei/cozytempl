# Build context trimming. Everything here is either already generated
# inside the builder stages or irrelevant to the final image.

.git
.github
.vscode
.idea

# Local build outputs — rebuilt inside the container anyway.
bin/
dist/

# TypeScript intermediate output — regenerated by the webbuilder stage
# so the build context stays identical whether or not the developer has
# run `make build` locally first.
static/dist/
node_modules/

# Helm chart + docs are irrelevant to the runtime image. Keeping them
# out of the build context speeds up cache invalidation on unrelated
# chart tweaks.
deploy/
docs/
*.md
