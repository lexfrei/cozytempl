package layout

import "github.com/lexfrei/cozytempl/static"

templ Base(title string) {
	<!DOCTYPE html>
	<html lang="en">
	<head>
		<meta charset="UTF-8"/>
		<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
		<meta name="referrer" content="same-origin"/>
		<meta http-equiv="X-Content-Type-Options" content="nosniff"/>
		<title>{ title } — cozytempl</title>
		<link rel="stylesheet" href={ "/static/css/styles.css?v=" + static.AssetVersion() }/>
		<script defer src={ "/static/dist/bundle.js?v=" + static.AssetVersion() }></script>
	</head>
	<body>
		<div id="htmx-progress-bar" aria-hidden="true"></div>
		{ children... }
	</body>
	</html>
}
